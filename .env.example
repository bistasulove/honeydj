# Django
DJANGO_SETTINGS_MODULE=honeydj.settings.local
SECRET_KEY=change-me-in-production-use-50-random-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgres://honeydj:honeydj@db:5432/honeydj

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# GeoIP (optional — path inside container)
GEOIP_PATH=/app/geoip

# Email (optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=honeydj@localhost
